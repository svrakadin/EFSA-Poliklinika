<Page x:Class="DesktopDemo.RequestsScreen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RequestsScreen"
      Background="#EAF4FB">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAV BAR -->
        <Border Grid.Row="0"
                Background="#0B5ED7"
                Padding="10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Moji zahtjevi"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Content="Početna"
                            Padding="10,5"
                            Margin="0,0,10,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="White"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="Home_Click"/>

                    <Button Content="Kreiraj zahtjev"
                            Padding="10,5"
                            Background="White"
                            Foreground="#0B5ED7"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CreateRequest_Click"/>

                </StackPanel>

            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1">

            <StackPanel Margin="20">

                <TextBlock Text="Pregled svih zahtjeva"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1E4F7A"
                           Margin="0,0,0,20"/>

                <ItemsControl x:Name="RequestsList">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="White"
                                    Padding="15"
                                    Margin="0,0,0,10"
                                    CornerRadius="12"
                                    BorderBrush="#E6E6E6"
                                    BorderThickness="1">

                                <StackPanel>

                                    <TextBlock Text="{Binding TipPregleda}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="#1E4F7A"
                                               Margin="0,0,0,10"/>

                                    <TextBlock>
                                        <Run Text="Datum: "/>
                                        <Run Text="{Binding Datum}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Vrijeme: "/>
                                        <Run Text="{Binding Vrijeme}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Doktor: "/>
                                        <Run Text="{Binding Specijalista}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Mjesto: "/>
                                        <Run Text="{Binding Mjesto}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Karton: "/>
                                        <Run Text="{Binding Karton}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding Status}"
                                               FontWeight="Bold"
                                               Margin="0,10,0,0">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Status}" Value="NA ČEKANJU">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Status}" Value="FINALIZIRANO">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Status}" Value="ODBIJENO">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</Page>